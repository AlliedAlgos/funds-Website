---
import MainLayout from '../layouts/mainLayout.astro';
import { pb } from '../lib/pocketbase';

let donations = [];
let totalAmount = 0;

try {
  donations = await pb.collection('donations').getFullList({
    filter: 'campaign.name ~ "allied-algorithms"', 
    expand: 'campaign',
    sort: '-created',
  });

  totalAmount = donations.reduce((sum, item) => sum + (item.amount || 0), 0);
  
} catch (e) {
  console.error("PocketBase Error:", e);
}

const formatCurrency = (num) => {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(num);
};
---

<MainLayout title="Funds - Allied Algorithms">
  <div class="py-4 md:py-8 px-4 max-w-4xl mx-auto">
    
    <div class="mb-8 bg-blue-600 p-6 md:p-10 rounded-[2rem] text-white shadow-xl shadow-blue-100 text-center">
        <h1 class="text-3xl md:text-5xl font-black tracking-tight mb-4">
            <span class="border-b-4 border-blue-400">AlliedAlgos</span>
        </h1>
        <p class="text-blue-100 text-[10px] font-bold uppercase tracking-[0.2em] mb-1">Total Funds Raised</p>
        <h2 class="text-4xl md:text-6xl font-black tracking-tight">{formatCurrency(totalAmount)}</h2>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      
      <div class="block md:hidden divide-y divide-gray-100">
        {donations.map((item) => (
          <div class="p-5 active:bg-gray-50 transition-colors">
            <div class="flex justify-between items-start mb-1">
              <div class="flex flex-col">
                <span class="text-base font-bold text-gray-900">{item.name || "Anonymous"}</span>
                <span class="text-xs text-gray-500 font-medium">{item.email}</span>
              </div>
              <div class="text-right">
                <div class="text-lg font-black text-blue-600">{formatCurrency(item.amount)}</div>
                <div class="text-[10px] text-gray-400 font-bold uppercase">
                  {new Date(item.created).toLocaleDateString()}
                </div>
              </div>
            </div>
            {item.message && (
              <p class="mt-2 text-sm text-gray-600 italic leading-relaxed bg-gray-50 p-3 rounded-lg">
                "{item.message}"
              </p>
            )}
          </div>
        ))}
      </div>

      <table class="hidden md:table w-full text-left table-auto">
        <thead class="bg-gray-50 border-b border-gray-100">
          <tr>
            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-wider text-gray-400">Donor</th>
            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-wider text-gray-400">Message</th>
            <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-wider text-gray-400 text-right">Amount</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          {donations.map((item) => (
            <tr class="hover:bg-gray-50/50 transition-colors group">
              <td class="px-6 py-5 whitespace-nowrap">
                <div class="flex flex-col">
                  <span class="text-sm font-bold text-gray-900">{item.name || "Anonymous"}</span>
                  <span class="text-xs text-gray-500 font-medium">{item.email}</span>
                </div>
              </td>
              <td class="px-6 py-5">
                <p class="text-sm text-gray-600 max-w-xs italic line-clamp-2">
                  {item.message || "—"}
                </p>
              </td>
              <td class="px-6 py-5 text-right">
                <div class="text-lg font-black text-gray-900">{formatCurrency(item.amount)}</div>
                <div class="text-[10px] text-gray-400 font-medium uppercase mt-1">
                  {new Date(item.created).toLocaleDateString()}
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      
      {donations.length === 0 && (
        <div class="py-20 px-6 text-center text-gray-400">
            <p class="font-medium">No records found yet.</p>
        </div>
      )}
    </div>
  </div>
</MainLayout>