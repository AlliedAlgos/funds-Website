---
import MainLayout from '../layouts/mainLayout.astro';
import { pb } from '../lib/pocketbase';

let donations = [];
let totalAmount = 0;

// FIX: Added the missing helper function used in the HTML below
const formatCurrency = (amount) => 
  new Intl.NumberFormat('en-US', { 
    style: 'currency', 
    currency: 'USD' 
  }).format(amount || 0);

try {
  donations = await pb.collection('donations').getFullList({
    filter: 'campaign.name ~ "allied-algorithms"',
    sort: '-created', // Newest donations first
  });

  totalAmount = donations.reduce((sum, d) => sum + (d.amount || 0), 0);
} catch (err) {
  console.error("PocketBase Error:", err);
}
---

<MainLayout title="Funds - Allied Algorithms">
  <div class="py-6 md:py-10 px-4 max-w-4xl mx-auto">

    <!-- TOTAL FUNDS CARD -->
    <section class="mb-10 bg-blue-600 p-8 md:p-12 rounded-[2rem] text-white shadow-xl shadow-blue-100 text-center">
      <h1 class="text-3xl md:text-5xl font-black tracking-tight mb-4">
        <span class="border-b-4 border-blue-400">AlliedAlgos</span>
      </h1>
      <p class="text-blue-100 text-[11px] font-bold uppercase tracking-[0.2em] mb-1">
        Total Funds Raised
      </p>
      <h2 class="text-4xl md:text-6xl font-black tracking-tight">
        ${totalAmount.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
      </h2>
    </section>

    <!-- DONATION LIST -->
    <section class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

      <!-- MOBILE LIST -->
      <div class="md:hidden divide-y divide-gray-100">
        {donations.map((d) => (
          <div class="p-5 active:bg-gray-50 transition-colors">
            <div class="flex justify-between items-start mb-1">
              <div>
                <span class="text-base font-bold text-gray-900">
                  {d.name || "Anonymous"}
                </span>
                <span class="block text-xs text-gray-500 font-medium">
                  {d.email}
                </span>
              </div>

              <div class="text-right">
                <div class="text-lg font-black text-blue-600">
                  {formatCurrency(d.amount)}
                </div>
                <div class="text-[10px] text-gray-400 font-bold uppercase">
                  {new Date(d.created).toLocaleDateString()}
                </div>
              </div>
            </div>

            {d.message && (
              <p class="mt-3 text-sm text-gray-600 italic leading-relaxed bg-gray-50 p-3 rounded-lg">
                "{d.message}"
              </p>
            )}
          </div>
        ))}
      </div>

      <!-- DESKTOP TABLE -->
      <table class="hidden md:table w-full text-left table-auto">
        <thead class="bg-gray-50 border-b border-gray-100">
          <tr>
            <th class="px-6 py-4 text-[11px] font-bold uppercase tracking-wider text-gray-400">Donor</th>
            <th class="px-6 py-4 text-[11px] font-bold uppercase tracking-wider text-gray-400">Message</th>
            <th class="px-6 py-4 text-[11px] font-bold uppercase tracking-wider text-gray-400 text-right">Amount</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-50">
          {donations.map((d) => (
            <tr class="hover:bg-gray-50/50 transition-colors">
              <td class="px-6 py-5 whitespace-nowrap">
                <div>
                  <span class="text-sm font-bold text-gray-900">
                    {d.name || "Anonymous"}
                  </span>
                  <span class="block text-xs text-gray-500 font-medium">
                    {d.email}
                  </span>
                </div>
              </td>

              <td class="px-6 py-5">
                <p class="text-sm text-gray-600 max-w-xs italic line-clamp-2" title={d.message}>
                  {d.message || "—"}
                </p>
              </td>

              <td class="px-6 py-5 text-right">
                <div class="text-lg font-black text-gray-900">
                  {formatCurrency(d.amount)}
                </div>
                <div class="text-[10px] text-gray-400 font-medium uppercase mt-1">
                  {new Date(d.created).toLocaleDateString()}
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>

      {donations.length === 0 && (
        <div class="py-20 px-6 text-center text-gray-400">
          <p class="font-medium">No records found yet.</p>
        </div>
      )}
    </section>
  </div>
</MainLayout>
