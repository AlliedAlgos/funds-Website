---
import MainLayout from '../layouts/mainLayout.astro';
---

<MainLayout title="Funds - Allied Algorithms">
  <div id="loader" class="fixed inset-0 bg-white z-50 flex flex-col items-center justify-center">
    <div class="w-10 h-10 border-4 border-blue-600 border-t-transparent rounded-full animate-spin mb-4"></div>
    <p class="text-gray-500 font-medium animate-pulse">Verifying Session...</p>
  </div>

  <div id="login-overlay" class="fixed inset-0 bg-gray-50 z-40 flex items-center justify-center px-4 hidden">
    <div class="max-w-md w-full bg-white p-8 rounded-3xl shadow-2xl border border-gray-100">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-black text-gray-900">Admin Login</h2>
        <p class="text-gray-500 mt-2">Allied Algorithms Dashboard</p>
      </div>
      <form id="login-form" class="space-y-4">
        <input type="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none focus:ring-2 focus:ring-blue-500" placeholder="Email" />
        <input type="password" name="password" required class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none focus:ring-2 focus:ring-blue-500" placeholder="Password" />
        <button type="submit" class="w-full bg-blue-600 text-white font-bold py-3 rounded-xl shadow-lg active:scale-95 transition-all">Sign In</button>
        <p id="error-msg" class="text-red-500 text-sm text-center font-medium hidden"></p>
      </form>
    </div>
  </div>

  <div id="dashboard" class="hidden">
    <div class="max-w-4xl mx-auto px-4 pt-6 text-right">
      <button id="logout-btn" class="text-[10px] font-black text-gray-400 hover:text-red-500 transition-colors uppercase tracking-[0.2em]">
        Log Out Session
      </button>
    </div>

    <div class="py-6 md:py-10 px-4 max-w-4xl mx-auto">
      <section class="mb-10 bg-blue-600 p-8 md:p-12 rounded-[2rem] text-white shadow-xl shadow-blue-100 text-center">
        <h1 class="text-3xl md:text-5xl font-black tracking-tight mb-4">AlliedAlgos</h1>
        <p class="text-blue-100 text-[11px] font-bold uppercase tracking-[0.2em] mb-1">Total Funds Raised</p>
        <h2 id="total-display" class="text-4xl md:text-6xl font-black tracking-tight">$0.00</h2>
      </section>

      <section class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div id="donations-list" class="divide-y divide-gray-100">
          <div class="p-20 text-center text-gray-400 font-medium">Loading donations...</div>
        </div>
      </section>
    </div>
  </div>
</MainLayout>

<script>
  import { pb } from '../lib/pocketbase';

  const loader = document.getElementById('loader');
  const loginOverlay = document.getElementById('login-overlay');
  const dashboard = document.getElementById('dashboard');
  const loginForm = document.getElementById('login-form');
  const donationsList = document.getElementById('donations-list');
  const totalDisplay = document.getElementById('total-display');

  async function init() {
    if (!pb.authStore.isValid) {
      showLogin();
    } else {
      await loadData();
    }
  }

  function showLogin() {
    loader?.classList.add('hidden');
    loginOverlay?.classList.remove('hidden');
    dashboard?.classList.add('hidden');
  }

  async function loadData() {
    try {
      // FIX 1: Explicitly target the campaign field. 
      // If 'campaign' is a relation to a collection that has a 'name' field, use campaign.name
      const records = await pb.collection('donations').getFullList({
        sort: '-created',
        filter: 'campaign.name ~ "allied-algorithms"', 
        expand: 'campaign', // Ensure the related campaign data is loaded
      });

      renderData(records);
      
      loader?.classList.add('hidden');
      dashboard?.classList.remove('hidden');
      loginOverlay?.classList.add('hidden');
    } catch (err) {
      console.error("Data Load Error:", err);
      // If filtering fails, we try loading without the filter once to diagnose
      if (err.status === 400) {
          console.warn("Filter failed. Checking permissions or field names.");
      }
    }
  }

  function renderData(donations) {
    if (!donationsList || !totalDisplay) return;

    if (donations.length === 0) {
      donationsList.innerHTML = `<div class="p-20 text-center text-gray-400">No records found for this campaign.</div>`;
      totalDisplay.innerText = "$0.00";
      return;
    }

    const total = donations.reduce((sum, d) => sum + (d.amount || 0), 0);
    totalDisplay.innerText = new Intl.NumberFormat('en-US', { 
      style: 'currency', currency: 'USD' 
    }).format(total);

    donationsList.innerHTML = donations.map(d => `
      <div class="p-5 flex justify-between items-center hover:bg-gray-50 transition-colors">
        <div>
          <span class="block font-bold text-gray-900">${d.name || 'Anonymous'}</span>
          <span class="text-xs text-gray-500">${d.email || ''}</span>
          ${d.message ? `<p class="text-sm text-gray-600 italic mt-1">"${d.message}"</p>` : ''}
        </div>
        <div class="text-right">
          <span class="block font-black text-blue-600 text-lg">$${(d.amount || 0).toLocaleString()}</span>
          <span class="text-[10px] text-gray-400 font-bold uppercase">${new Date(d.created).toLocaleDateString()}</span>
        </div>
      </div>
    `).join('');
  }

  loginForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(loginForm);
    const errorMsg = document.getElementById('error-msg');

    try {
      // FIX 2: Changed '.collection('user')' to '.collection('users')' (standard plural)
      // FIX 3: If you are an ADMIN (not a user), use pb.admins.authWithPassword
      await pb.collection('users').authWithPassword(
        data.get('email'), 
        data.get('password')
      );
      window.location.reload(); 
    } catch (err) {
      if (errorMsg) {
        errorMsg.innerText = "Invalid Credentials. Check if you are a 'User' or 'Admin'.";
        errorMsg.classList.remove('hidden');
      }
    }
  });

  document.getElementById('logout-btn')?.addEventListener('click', () => {
    pb.authStore.clear();
    window.location.reload();
  });

  init();
</script>